# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv
.Rproj.user

# R session files
.Rhistory
.RData
.RDataTmp

# Project data (keep raw and intermediate data out of git)
01-input/
02-output/
